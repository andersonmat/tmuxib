{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "shared/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx"
  ]
}
