{
  "name": "tmuxib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:server": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "rm -rf dist && bun run build:exe",
    "build:server": "mkdir -p dist && bun run scripts/build.ts server",
    "build:exe": "mkdir -p dist && bun run scripts/build.ts exe",
    "check": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "hono": "^4.12.9",
    "node-pty": "^1.1.0",
    "preact": "^10.27.2"
  }
}
