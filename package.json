{
  "name": "tmuxib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --watch src/index.ts",
    "dev:client": "mkdir -p .client/public && bun build --watch --no-clear-screen --compile --target=browser --outfile .client/public/index.html public/index.html",
    "start": "bun run build:client:dev && bun run src/index.ts",
    "build": "rm -rf dist && bun run build:client && bun run build:server && mkdir -p dist/bin && cp bin/pty-bridge.mjs dist/bin/pty-bridge.mjs",
    "build:client": "mkdir -p dist/public && bun build --compile --target=browser --minify --outfile dist/public/index.html public/index.html",
    "build:client:dev": "rm -rf .client && mkdir -p .client/public && bun build --compile --target=browser --outfile .client/public/index.html public/index.html",
    "build:server": "bun build --target bun --outfile dist/server/index.js src/index.ts",
    "check": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "hono": "^4.12.9",
    "node-pty": "^1.1.0",
    "preact": "^10.27.2"
  }
}
